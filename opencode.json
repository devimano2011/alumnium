{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "doom_loop": "ask",
    "external_directory": "ask"
  },
  "mcp": {
    "alumnium": {
      "type": "local",
      "command": ["mise", ":dev/mcp"],
      "enabled": true,
      "environment": {
        "ALUMNIUM_LOG_LEVEL": "{env:ALUMNIUM_LOG_LEVEL}",
        "ALUMNIUM_LOG_FILENAME": "mcp-opencode.log",
        "ALUMNIUM_DRIVER": "{env:ALUMNIUM_DRIVER}",
        "ALUMNIUM_MODEL": "{env:ALUMNIUM_MODEL}",
        "ALUMNIUM_PLANNER": "{env:ALUMNIUM_PLANNER}",
        "ALUMNIUM_PLAYWRIGHT_HEADLESS": "{env:ALUMNIUM_PLAYWRIGHT_HEADLESS}",
        "AZURE_OPENAI_API_VERSION": "{env:AZURE_OPENAI_API_VERSION}",
        "ALUMNIUM_TRACE": "{env:ALUMNIUM_TRACE}",
        "OTEL_SERVICE_NAME": "{env:OTEL_SERVICE_NAME}",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "{env:OTEL_EXPORTER_OTLP_ENDPOINT}",
        "OTEL_EXPORTER_OTLP_PROTOCOL": "{env:OTEL_EXPORTER_OTLP_PROTOCOL}"
      },
      "timeout": 120000
    }
  }
}
