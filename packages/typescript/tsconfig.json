{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Base",
  "include": [
    "./*.ts",
    "./src/**/*.ts",
    "./scripts/**/*.ts",
    "./tests/**/*.ts",
    "./package.json"
  ],
  "compilerOptions": {
    // Resolve
    "rootDir": ".",
    "paths": {},
    // Output
    "target": "esnext",
    "outDir": "./.ts",
    "tsBuildInfoFile": "./.ts/tsconfig.tsbuildinfo",
    "emitDeclarationOnly": true,
    // Modules
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "isolatedModules": true,
    "moduleDetection": "force", // Stop treating files without imports/exports as single global scripts
    "allowImportingTsExtensions": true, // Use .ts extensions to make imports work in Node.js
    "verbatimModuleSyntax": true, // Enforce type-only imports
    "resolveJsonModule": true,
    // Env
    "lib": ["ESNext"],
    "types": ["bun", "@wdio/globals/types"],
    "erasableSyntaxOnly": true, // Disallow using using runtime TS features
    // TODO: Remove and use ES decorators when Oxc gets support for them:
    // https://github.com/oxc-project/oxc/issues/9170
    "experimentalDecorators": true,
    // Checks
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true, // Force using override modifier in classes
    "checkJs": true, // Allow using JSDoc to type check JavaScript files
    // Build
    "incremental": true,
    // Project references
    "composite": true
  }
}
