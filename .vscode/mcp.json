{
  "servers": {
    "alumnium": {
      "type": "stdio",
      "command": "mise",
      "args": [":dev/mcp"],
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "ALUMNIUM_LOG_LEVEL": "${env:ALUMNIUM_LOG_LEVEL}",
        "ALUMNIUM_LOG_FILENAME": "mcp-vscode.log",
        "ALUMNIUM_DRIVER": "${env:ALUMNIUM_DRIVER}",
        "ALUMNIUM_MODEL": "${env:ALUMNIUM_MODEL}",
        "ALUMNIUM_PLANNER": "${env:ALUMNIUM_PLANNER}",
        "ALUMNIUM_PLAYWRIGHT_HEADLESS": "${env:ALUMNIUM_PLAYWRIGHT_HEADLESS}",
        "AZURE_OPENAI_API_VERSION": "${env:AZURE_OPENAI_API_VERSION}"
      }
    }
  }
}
